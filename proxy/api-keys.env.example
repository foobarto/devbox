# devbox API keys — host-side secrets. NEVER commit the filled-in copy.
#
# Two consumers:
#   * `devbox --api-keys`  copies this file into the box as /etc/profile.d/*.sh
#     so the CLIs read the keys directly (keys DO enter the box).
#   * proxy/run.sh sources it so the host proxy can inject keys while they stay
#     on the host (keys do NOT enter the box) — use with `devbox --proxy`.
#
# Copy to ~/.config/devbox/api-keys.env and fill in.

export ANTHROPIC_API_KEY=""
export OPENAI_API_KEY=""

# opencode / stado and other multi-provider tools read these too as needed:
# export OPENROUTER_API_KEY=""
# export GROQ_API_KEY=""
# export GEMINI_API_KEY=""
