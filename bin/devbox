#!/usr/bin/env bash
#
# devbox — disposable, CWD-mounted dev VMs on Lima/QEMU, preloaded with an
# AI-CLI toolchain (claude, codex, opencode, stado) + Homebrew.
#
# Model
#   A one-time "golden" Lima instance per base image carries the toolchain.
#   Each `devbox` run clones the golden into an instance whose name is derived
#   deterministically from the target directory — so a given folder always maps
#   to the same box (one box per folder), and different folders get different
#   boxes. The clone mounts the folder, drops you into a shell, and is deleted
#   on exit (unless --keep, or it pre-existed).
#
# Usage
#   devbox [DIR] [FLAGS]        spin/attach a box for DIR (default: $PWD)
#   devbox build [--image N] [--force]
#   devbox ls
#   devbox destroy NAME | --all | --goldens
#   devbox proxy [start|stop|status]   manage the shared host-side AI proxy
#   devbox --version
#
# Run flags
#   --image NAME     base image for this box's golden (default: ubuntu-24.04).
#                    NAME may be a Lima template name (ubuntu-24.04, debian-12,
#                    fedora, archlinux, …), a template:// URL, a path to a
#                    *.yaml Lima config, or a path/URL to a *.qcow2/*.img image
#                    (e.g. a Kali cloud image).
#   --keep           do not auto-delete the box on shell exit.
#   --ssh-agent      forward the host SSH agent into the box (git/GitHub auth)
#                    and configure SSH-signed commits; private keys stay host-side.
#   --proxy[=URL]    point the AI CLIs at a host-side proxy (default
#                    http://host.lima.internal:4141); real credentials stay on
#                    the host. Auto-starts the proxy on this host if it isn't
#                    already running (shared across boxes). See proxy/README.md.
#   --no-auth        do not inject proxy, API-key, or copied host credentials;
#                    also removes devbox-managed proxy/key profiles from an
#                    existing box. This is the default for a new box.
#   --api-keys[=F]   inject API keys into the box from env file F
#                    (default ~/.config/devbox/api-keys.env).
#   --with-creds     copy host AI-tool credential files into the box (OAuth
#                    logins for claude/codex without a proxy). Best-effort.
#   --mount P[:ro|:rw]  mount an extra host path into the box at the same path
#                    (default ro). Repeatable. Applied at box creation.
#   --copy SRC[:DEST]   copy an extra host file/dir into the box (DEST defaults
#                    to the basename in $HOME). Repeatable. Works on new+existing.
#   --name NAME      override the derived instance name.
#
# Env
#   DEVBOX_CONFIG_DIR   config/golden dir (default ~/.config/devbox)
#   DEVBOX_PROXY_URL    default --proxy URL
#
set -euo pipefail

# ---------------------------------------------------------------- constants --
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VERSION_FILE="$SCRIPT_DIR/../VERSION"
DEVBOX_VERSION="$(tr -d '[:space:]' < "$VERSION_FILE" 2>/dev/null || printf 'dev')"
DEFAULT_IMAGE="ubuntu-24.04"
CONFIG_DIR="${DEVBOX_CONFIG_DIR:-$HOME/.config/devbox}"
DEFAULT_KEYS_FILE="$CONFIG_DIR/api-keys.env"
PROXY_DEFAULT_URL="${DEVBOX_PROXY_URL:-http://host.lima.internal:4141}"
PROJECT_MANIFEST_NAME=".devbox.toml"

# Host credential paths copied into the box under --with-creds (best-effort;
# only those that exist are copied). Tune to taste. Deliberately excludes
# ~/.ssh / ~/.gnupg — use --ssh-agent for git, and never ship private keys.
CRED_PATHS=(
  "$HOME/.claude.json"
  "$HOME/.claude/.credentials.json"
  "$HOME/.codex/auth.json"
  "$HOME/.codex/config.toml"
  "$HOME/.config/opencode"
  "$HOME/.local/share/opencode/auth.json"
  "$HOME/.config/stado"
)

# ------------------------------------------------------------------- output --
_c() { [[ -t 2 ]] && printf '\033[%sm' "$1" >&2 || true; }
log()  { _c '1;34'; printf '[devbox]'   >&2; _c 0; printf ' %s\n' "$*" >&2; }
warn() { _c '1;33'; printf '[devbox] WARN:' >&2; _c 0; printf ' %s\n' "$*" >&2; }
die()  { _c '1;31'; printf '[devbox] ERROR:' >&2; _c 0; printf ' %s\n' "$*" >&2; exit 1; }
need() { command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"; }

abspath() { readlink -f -- "$1" 2>/dev/null || printf '%s' "$1"; }

# -------------------------------------------------------------- name helpers --
_slug() { # sanitize $1 -> lowercase [a-z0-9-], collapse, trim, cap length $2
  local s; s="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]' \
      | tr -c 'a-z0-9' '-' | sed -E 's/-+/-/g; s/^-|-$//g')"
  [[ -z "$s" ]] && s="x"
  printf '%s' "${s:0:${2:-30}}"
}

imgslug() { # stable short slug for an image spec (name or path/URL)
  local img="$1" base; base="$(_slug "$(basename -- "$img")" 20)"
  case "$img" in
    */*|*.qcow2|*.img|*.raw)
      printf '%s-%s' "$base" "$(printf '%s' "$img" | sha1sum | cut -c1-6)";;
    *) printf '%s' "$(_slug "$img" 30)";;
  esac
}

golden_name()   { printf 'devbox-golden-%s' "$(imgslug "$1")"; }

instance_name() { # deterministic per (image, absolute dir)
  local image="$1" dir="$2" slug hash
  slug="$(_slug "$(basename -- "$dir")" 24)"
  hash="$(printf '%s\0%s' "$image" "$dir" | sha1sum | cut -c1-8)"
  printf 'devbox-%s-%s' "$slug" "$hash"
}

# ---------------------------------------------------------------- lima state --
instance_exists() { limactl list -q 2>/dev/null | grep -qx "$1"; }
instance_status() { limactl list "$1" --format '{{.Status}}' 2>/dev/null || echo Unknown; }
ensure_golden_stopped() {
  [[ "$(instance_status "$1")" == "Running" ]] || return 0
  log "Stopping golden $1 before clone"; limactl stop "$1"
}

require_ssh_agent() {
  [[ -n "${SSH_AUTH_SOCK:-}" && -S "${SSH_AUTH_SOCK:-}" ]] || \
    die "--ssh-agent needs a running host SSH agent (SSH_AUTH_SOCK is unset or not a socket)"
}

ssh_agent_forwarding_enabled() {
  limactl list "$1" --json 2>/dev/null | python3 -c '
import json, sys
try:
    print(json.load(sys.stdin)["config"]["ssh"]["forwardAgent"] is True)
except (json.JSONDecodeError, KeyError, TypeError):
    print(False)
'
}

enable_ssh_agent() { # $1 instance; restart only when its persisted config changes
  local name="$1" status
  require_ssh_agent
  [[ "$(ssh_agent_forwarding_enabled "$name")" == True ]] && return 0

  status="$(instance_status "$name")"
  if [[ "$status" == "Running" ]]; then
    log "Restarting $name to enable host SSH-agent forwarding"
    limactl stop "$name"
  fi
  log "Enabling host SSH-agent forwarding"
  limactl edit "$name" --set '.ssh.forwardAgent = true' >/dev/null
  [[ "$status" == "Running" ]] && limactl start "$name"
}

ssh_signing_public_key() {
  local key
  key="$(ssh-add -L 2>/dev/null | sed -n '1p')"
  [[ -n "$key" ]] || die "--ssh-agent needs an identity loaded in the host SSH agent to sign Git commits"
  printf '%s\n' "$key" | ssh-keygen -lf - >/dev/null 2>&1 \
    || die "the first identity from the host SSH agent is not a valid SSH public key"
  printf '%s' "$key"
}

apply_git_signing() { # $1 instance; SSH signatures use the forwarded agent
  local name="$1" key git_name git_email
  key="$(ssh_signing_public_key)"
  git_name="$(git config --global --get user.name 2>/dev/null || true)"
  git_email="$(git config --global --get user.email 2>/dev/null || true)"
  [[ -n "$git_name" && -n "$git_email" ]] || \
    die "configure host Git user.name and user.email before using --ssh-agent for signed commits"
  log "Configuring Git SSH commit signing through the forwarded agent"
  python3 - "$key" "$git_name" "$git_email" <<'PY' \
    | limactl shell "$name" -- python3 -c '
import json
import pathlib
import subprocess
import sys

config = json.load(sys.stdin)
devbox_dir = pathlib.Path.home() / ".devbox"
devbox_dir.mkdir(mode=0o700, exist_ok=True)
public_key = devbox_dir / "git-signing-key.pub"
allowed_signers = devbox_dir / "git-allowed-signers"
public_key.write_text(config["key"] + "\n")
public_key.chmod(0o644)
allowed_signers.write_text("{} namespaces=\"git\" {}\n".format(config["email"], config["key"]))
allowed_signers.chmod(0o644)

def set_global(key, value):
    subprocess.run(["git", "config", "--global", key, value], check=True)

# Git 2.34+ can delegate SSH-format signatures to SSH_AUTH_SOCK. Only the
# public key crosses into the guest; ssh-keygen asks the forwarded agent to sign.
set_global("gpg.format", "ssh")
set_global("user.signingkey", str(public_key))
set_global("gpg.ssh.allowedSignersFile", str(allowed_signers))
set_global("commit.gpgsign", "true")
for key, value in (("user.name", config["name"]), ("user.email", config["email"])):
    current = subprocess.run(
        ["git", "config", "--global", "--get", key], text=True, capture_output=True
    )
    if current.returncode != 0 or not current.stdout.strip():
        set_global(key, value)
'
import json
import sys
print(json.dumps({"key": sys.argv[1], "name": sys.argv[2], "email": sys.argv[3]}))
PY
}

# ---------------------------------------------------------- golden yaml gen --
emit_base_stanza() {
  local image="$1" t
  case "$image" in
    http://*|https://*)   printf 'images:\n- location: "%s"\n  arch: "x86_64"\n' "$image";;
    template:*)           t="${image#template:}"; t="${t#//}"; printf 'base: "template:%s"\n' "$t";;
    *.yaml|*.yml)         printf 'base: "%s"\n' "$(abspath "$image")";;
    *.qcow2|*.img|*.raw)  printf 'images:\n- location: "%s"\n  arch: "x86_64"\n' "$(abspath "$image")";;
    *)                    printf 'base: "template:%s"\n' "$image";;
  esac
}

emit_golden_yaml() { # $1 image  $2 outfile
  local image="$1" out="$2"
  {
    printf '# devbox golden — regenerate with: devbox build --image %s --force\n' "$image"
    emit_base_stanza "$image"
    cat <<'YAML'
cpus: 4
memory: "6GiB"
disk: "50GiB"
mountType: "virtiofs"
# No host mount on the golden — the per-run CWD mount is added at clone time and
# would otherwise overlap the stock template's ~ mount.
mounts: []
ssh:
  loadDotSSHPubKeys: false   # host pubkeys are not copied in; use --ssh-agent
provision:
- mode: system
  script: |
    #!/bin/bash
    set -eu
    export DEBIAN_FRONTEND=noninteractive
    apt="build-essential git curl wget jq ripgrep unzip ca-certificates procps file locales sudo python3 python3-venv python3-pip"
    dnf="@development-tools git curl wget jq ripgrep unzip ca-certificates procps-ng file glibc-langpack-en sudo python3 python3-pip"
    pac="base-devel git curl wget jq ripgrep unzip ca-certificates procps-ng file sudo python python-pip"
    if   command -v apt-get >/dev/null 2>&1; then apt-get update && apt-get install -y --no-install-recommends $apt
    elif command -v dnf     >/dev/null 2>&1; then dnf install -y $dnf
    elif command -v pacman  >/dev/null 2>&1; then pacman -Sy --noconfirm $pac
    fi
- mode: user
  script: |
    #!/bin/bash
    set -eu
    # PATH + brew shellenv for every login shell (bash/zsh/sh).
    for rc in "$HOME/.profile" "$HOME/.bashrc" "$HOME/.zshrc"; do
      touch "$rc"
      grep -q 'linuxbrew/.linuxbrew/bin/brew shellenv' "$rc" 2>/dev/null || \
        echo 'eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"' >> "$rc"
      grep -q 'devbox PATH' "$rc" 2>/dev/null || \
        echo 'export PATH="$HOME/.local/bin:$HOME/go/bin:$HOME/.opencode/bin:$PATH" # devbox PATH' >> "$rc"
    done
    # --- Homebrew (Linuxbrew): distro-agnostic base for the AI CLIs ---
    if [ ! -x /home/linuxbrew/.linuxbrew/bin/brew ] && ! command -v brew >/dev/null 2>&1; then
      NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" || true
    fi
    BREW="$(command -v brew || echo /home/linuxbrew/.linuxbrew/bin/brew)"
    [ -x "$BREW" ] && eval "$("$BREW" shellenv)" || true
    export PATH="$HOME/.local/bin:$HOME/go/bin:$HOME/.opencode/bin:$PATH"
    # --- AI CLIs ---
    brew install codex || true
    brew install sst/tap/opencode || curl -fsSL https://opencode.ai/install | bash || true
    # stado — Homebrew cask (installs on Linux for this binary cask). Fallback to
    # a Go source install only if the cask ever fails (installs go on demand).
    if ! command -v stado >/dev/null 2>&1; then
      brew install --cask foobarto/tap/stado \
        || { brew install go && GOBIN="$HOME/.local/bin" go install github.com/foobarto/stado/cmd/stado@latest; } \
        || true
    fi
    # claude code — official native installer (-> ~/.local/bin)
    command -v claude >/dev/null 2>&1 || { curl -fsSL https://claude.ai/install.sh | bash || true; }
YAML
  } > "$out"
}

verify_golden() {
  local name="$1" out
  # shellcheck disable=SC2016 # $t and $(...) expand in the guest shell.
  out="$(limactl shell "$name" -- bash -lc '
    for t in brew claude codex opencode stado; do
      if command -v "$t" >/dev/null 2>&1; then printf "  ok   %-9s %s\n" "$t" "$(command -v "$t")"
      else printf "  MISS %-9s (not on PATH)\n" "$t"; fi
    done' </dev/null 2>/dev/null || true)"
  printf '%s\n' "$out" >&2
  if printf '%s' "$out" | grep -q MISS; then
    warn "some tools missing in golden — inspect with: limactl shell $name"
  fi
}

# ------------------------------------------------------------- auth wiring ---
# --- host-side AI proxy lifecycle (auto-started by --proxy) ----------------
# port of a proxy URL (default 4141)
proxy_port() {
  local hp="${1#*://}"; hp="${hp%%/*}"
  case "$hp" in *:*) printf '%s' "${hp##*:}";; *) printf '4141';; esac
}
# is *our* proxy answering on this port? (health endpoint, not just any listener)
proxy_health() { curl -fsS --max-time 1 "http://127.0.0.1:$1/_devbox" 2>/dev/null | grep -q 'devbox-ai-proxy'; }
# is anything at all listening on the port?
proxy_port_open() { timeout 1 bash -c ">/dev/tcp/127.0.0.1/$1" 2>/dev/null; }
# locate the proxy launcher across source (../proxy) and brew (../libexec/proxy)
# layouts, falling back to a devbox-ai-proxy on PATH.
proxy_launcher() {
  local self dir c
  self="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || printf '%s' "${BASH_SOURCE[0]}")"
  dir="$(dirname "$self")"
  for c in "$dir/../proxy/run.sh" "$dir/../libexec/proxy/run.sh"; do
    [[ -f "$c" ]] && { printf '%s' "$c"; return 0; }
  done
  command -v devbox-ai-proxy 2>/dev/null && return 0
  return 1
}
# start the host proxy if it isn't already up (idempotent). Shared across boxes.
proxy_ensure() {
  local url="$1" port launcher logf i
  port="$(proxy_port "$url")"
  if proxy_health "$port"; then log "AI proxy already running on 127.0.0.1:$port"; return 0; fi
  if proxy_port_open "$port"; then
    warn "port $port is held by another service (not devbox's proxy)."
    warn "  pick a free port: export DEVBOX_PROXY_URL=http://host.lima.internal:<PORT>"
    return 1
  fi
  launcher="$(proxy_launcher)" || { warn "proxy launcher not found — start it manually (devbox-ai-proxy)"; return 0; }
  mkdir -p "$CONFIG_DIR"; logf="$CONFIG_DIR/proxy.log"
  [[ -f "$CONFIG_DIR/api-keys.env" || -f "$CONFIG_DIR/proxy.config.json" || -f "$HOME/.claude/.credentials.json" ]] \
    || warn "no Anthropic key or host Claude login found — configure ~/.config/devbox/api-keys.env or run 'claude login'"
  log "Starting AI proxy on :$port  ($launcher)"
  setsid "$launcher" >"$logf" 2>&1 </dev/null &
  echo $! > "$CONFIG_DIR/proxy.pid"
  for i in $(seq 1 20); do proxy_health "$port" && break; sleep 0.2; done
  if proxy_health "$port"; then log "AI proxy up (pid $(cat "$CONFIG_DIR/proxy.pid" 2>/dev/null), log: $logf)"
  else warn "proxy did not come up — see $logf"; fi
}

apply_proxy() {
  local name="$1" url="$2" tmpl="$CONFIG_DIR/proxy-env"
  log "Wiring AI CLIs → proxy $url"
  if [[ -f "$tmpl" ]]; then
    sed "s|__PROXY_URL__|$url|g" "$tmpl" \
      | limactl shell "$name" -- bash -c 'sudo tee /etc/profile.d/zz-devbox-10-proxy.sh >/dev/null'
  else
    limactl shell "$name" -- bash -c 'sudo tee /etc/profile.d/zz-devbox-10-proxy.sh >/dev/null' <<EOF
# devbox --proxy: keep real credentials on the host proxy.
export ANTHROPIC_BASE_URL="$url"
export ANTHROPIC_API_KEY="\${ANTHROPIC_API_KEY:-devbox-proxy}"
export OPENAI_BASE_URL="$url/v1"
export OPENAI_API_KEY="\${OPENAI_API_KEY:-devbox-proxy}"
EOF
  fi
  # Codex's ChatGPT subscription flow uses a different backend than the public
  # OpenAI API. Give it an isolated, devbox-owned config pointing at the host
  # proxy. The dummy API key above is only a routing marker; no OAuth material
  # is written to the guest.
  limactl shell "$name" -- bash -c 'sudo tee /etc/profile.d/zz-devbox-11-codex-proxy.sh >/dev/null' <<'EOF'
# devbox --proxy: keep Codex's isolated proxy profile separate from user config.
export CODEX_HOME="$HOME/.devbox/codex-proxy"
EOF
  # shellcheck disable=SC2016 # $HOME expands in the guest shell.
  limactl shell "$name" -- bash -c 'umask 077; install -d -m 700 "$HOME/.devbox/codex-proxy"'
  # shellcheck disable=SC2016 # $HOME expands in the guest shell.
  python3 - "$url/backend-api/codex" <<'PY' \
    | limactl shell "$name" -- bash -c 'tee "$HOME/.devbox/codex-proxy/config.toml" >/dev/null; chmod 600 "$HOME/.devbox/codex-proxy/config.toml"'
import json
import sys
print(f"openai_base_url = {json.dumps(sys.argv[1])}")
PY
  # shellcheck disable=SC2016 # $HOME expands in the guest shell.
  limactl shell "$name" -- bash -c 'rm -f "$HOME/.devbox/codex-proxy/auth.json"'
}

apply_api_keys() {
  local name="$1" file="$2"
  [[ -f "$file" ]] || { warn "api-keys file not found: $file (skipping)"; return 0; }
  log "Injecting API keys from $file"
  limactl shell "$name" -- bash -c 'sudo tee /etc/profile.d/zz-devbox-20-keys.sh >/dev/null' < "$file"
}

clear_auth() {
  local name="$1"
  log "Disabling devbox-managed AI auth in $name"
  # shellcheck disable=SC2016 # $HOME expands in the guest shell.
  limactl shell "$name" -- bash -c \
    'sudo rm -f /etc/profile.d/zz-devbox-10-proxy.sh /etc/profile.d/zz-devbox-11-codex-proxy.sh /etc/profile.d/zz-devbox-20-keys.sh; rm -rf "$HOME/.devbox/codex-proxy"'
}

# PATH[:ro|:rw] -> a Lima --mount value (bare = read-only, :w suffix = writable).
_lima_mount_arg() {
  local spec="$1"
  case "$spec" in
    *:rw) printf '%s:w' "$(abspath "${spec%:rw}")";;
    *:ro) printf '%s'   "$(abspath "${spec%:ro}")";;
    *)    printf '%s'   "$(abspath "$spec")";;
  esac
}
# SRC[:DEST] split for --copy. No colon -> DEST is the basename (lands in $HOME).
_copy_src()  { local s="$1"; if [[ "$s" == *:* ]]; then printf '%s' "${s%:*}"; else printf '%s' "$s"; fi; }
_copy_dest() { local s="$1"; if [[ "$s" == *:* ]]; then printf '%s' "${s##*:}"; else basename -- "$s"; fi; }

apply_copy() {
  local name="$1" spec="$2" src dest parent rflag=()
  src="$(_copy_src "$spec")"; dest="$(_copy_dest "$spec")"
  [[ -e "$src" ]] || { warn "--copy source not found: $src"; return 0; }
  src="$(abspath "$src")"; parent="$(dirname "$dest")"
  [[ -d "$src" ]] && rflag=(-r)   # -r only for dirs; on a file it makes dest a dir
  log "Copying $src → $name:$dest"
  if [[ "$dest" == /* ]]; then
    limactl shell "$name" -- bash -c "sudo install -d -o \"\$(id -un)\" -g \"\$(id -gn)\" '$parent'" </dev/null 2>/dev/null || true
  else
    limactl shell "$name" -- bash -c "cd && mkdir -p '$parent'" </dev/null 2>/dev/null || true
  fi
  limactl copy "${rflag[@]}" "$src" "$name:$dest" 2>/dev/null || warn "copy failed: $src → $dest"
}

apply_creds() {
  local name="$1" p rel copied=0
  log "Copying host AI credentials into $name (best-effort)…"
  for p in "${CRED_PATHS[@]}"; do
    [[ -e "$p" ]] || continue
    case "$p" in "$HOME/"*) rel="${p#"$HOME"/}";; *) continue;; esac
    limactl shell "$name" -- bash -c "cd; mkdir -p '$(dirname "$rel")'" </dev/null 2>/dev/null || true
    if limactl copy -r "$p" "$name:$rel" 2>/dev/null; then copied=$((copied+1)); else warn "could not copy $p"; fi
  done
  log "Copied $copied credential path(s)."
}

# --------------------------------------------------------- project manifest --
project_manifest() { # $1 .devbox.toml -> normalized JSON
  python3 - "$1" <<'PY'
import json
import sys
from pathlib import Path

try:
    import tomllib
except ImportError:
    raise SystemExit("Python 3.11+ is required to read .devbox.toml")

path = Path(sys.argv[1])
try:
    data = tomllib.loads(path.read_text())
except (OSError, tomllib.TOMLDecodeError) as exc:
    raise SystemExit(f"could not read {path}: {exc}")

allowed = {
    "image", "packages", "start", "ssh_agent", "keep", "proxy", "api_keys",
    "with_creds", "no_auth", "mounts", "copies",
}
unknown = sorted(set(data) - allowed)
if unknown:
    raise SystemExit(f"unknown .devbox.toml key(s): {', '.join(unknown)}")

image = data.get("image")
if image is not None and (not isinstance(image, str) or not image):
    raise SystemExit("image must be a non-empty string")

packages = data.get("packages", [])
if not isinstance(packages, list) or any(not isinstance(p, str) or not p for p in packages):
    raise SystemExit("packages must be an array of non-empty Homebrew formula names")

start = data.get("start")
if start is not None and (not isinstance(start, str) or not start):
    raise SystemExit("start must be a non-empty shell command string")

for key in ("ssh_agent", "keep", "with_creds", "no_auth"):
    if key in data and not isinstance(data[key], bool):
        raise SystemExit(f"{key} must be true or false")

for key in ("proxy", "api_keys"):
    value = data.get(key, False)
    if not isinstance(value, (bool, str)) or isinstance(value, str) and not value:
        raise SystemExit(f"{key} must be true, false, or a non-empty path/URL string")

for key in ("mounts", "copies"):
    value = data.get(key, [])
    if not isinstance(value, list) or any(not isinstance(item, str) or not item for item in value):
        raise SystemExit(f"{key} must be an array of non-empty strings")

if data.get("no_auth") and (data.get("proxy") or data.get("api_keys") or data.get("with_creds")):
    raise SystemExit("no_auth cannot be combined with proxy, api_keys, or with_creds")

print(json.dumps({
    "image": image or "", "packages": packages, "start": start or "",
    "ssh_agent": data.get("ssh_agent", False), "keep": data.get("keep", False),
    "proxy": data.get("proxy", False), "api_keys": data.get("api_keys", False),
    "with_creds": data.get("with_creds", False), "no_auth": data.get("no_auth", False),
    "mounts": data.get("mounts", []), "copies": data.get("copies", []),
}))
PY
}

manifest_value() { # $1 normalized manifest JSON $2 key
  python3 -c 'import json, sys; print(json.load(sys.stdin)[sys.argv[1]])' "$2" <<< "$1"
}

manifest_json_value() { # $1 normalized manifest JSON $2 key
  python3 -c 'import json, sys; print(json.dumps(json.load(sys.stdin)[sys.argv[1]]))' "$2" <<< "$1"
}

apply_project_packages() { # $1 box name $2 normalized packages JSON
  local name="$1" packages="$2"
  [[ "$packages" != "[]" ]] || return 0
  log "Installing project packages from $PROJECT_MANIFEST_NAME"
  # shellcheck disable=SC2016 # the guest shell consumes this program.
  printf '%s' "$packages" | limactl shell "$name" -- bash -lc '
    python3 -c "import json, sys; print(*json.load(sys.stdin), sep=chr(0))" \
      | while IFS= read -r -d "" package; do
          brew list --versions "$package" >/dev/null 2>&1 || brew install "$package"
        done
  '
}

run_project_start() { # $1 box name $2 workdir $3 command
  local name="$1" dir="$2" command="$3"
  [[ -n "$command" ]] || return 0
  log "Running $PROJECT_MANIFEST_NAME start command"
  limactl shell --workdir "$dir" "$name" -- bash -lc "$command" </dev/null \
    || warn "$PROJECT_MANIFEST_NAME start command exited non-zero"
}

confirm_manifest_permissions() { # each argument is one requested capability
  local request answer
  [[ $# -gt 0 ]] || return 0
  printf '%s\n' "This devbox wants to:" >&2
  for request in "$@"; do printf '%s\n' "- $request" >&2; done
  printf '%s' 'Do you agree? [y/N] ' >&2
  if [[ -t 0 ]]; then
    read -r answer
  elif [[ -r /dev/tty ]]; then
    read -r answer </dev/tty
  else
    die "$PROJECT_MANIFEST_NAME requests host access, but no terminal is available to approve it"
  fi
  [[ "$answer" =~ ^[Yy]([Ee][Ss])?$ ]] || die "declined $PROJECT_MANIFEST_NAME host-access request"
}

# --------------------------------------------------------------- subcommands --
cmd_build() {
  local image="$DEFAULT_IMAGE" force=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --image) shift; image="${1:?--image needs a value}";;
      --image=*) image="${1#--image=}";;
      --force) force=1;;
      -h|--help) grep -E '^#( |$)' "$0" | sed -E 's/^# ?//'; return 0;;
      *) die "build: unknown arg: $1";;
    esac; shift
  done
  local golden gy; golden="$(golden_name "$image")"; gy="$CONFIG_DIR/${golden}.yaml"
  mkdir -p "$CONFIG_DIR"
  emit_golden_yaml "$image" "$gy"
  if instance_exists "$golden"; then
    if [[ $force -eq 1 ]]; then
      log "Rebuilding golden $golden…"
      limactl stop -f "$golden" 2>/dev/null || true; limactl delete -f "$golden"
    else
      log "Golden $golden already exists (use 'devbox build --image $image --force' to rebuild)."
      return 0
    fi
  fi
  log "Building golden $golden from image '$image' — this takes several minutes…"
  limactl start --name="$golden" "$gy"
  log "Verifying toolchain in $golden:"
  verify_golden "$golden"
  log "Stopping golden (retained as clone source)."
  limactl stop "$golden"
  log "Golden ready: $golden"
}

# Teardown runs from an EXIT/INT/TERM trap, which fires after cmd_run has
# returned — so its state must be global, not cmd_run locals (those are gone by
# then, and would trip `set -u`).
run_cleanup() {
  local rc=$?
  trap - EXIT INT TERM
  if [[ "${_DB_PRE:-0}" -eq 1 ]]; then
    log "Left box running: ${_DB_NAME:-?}  (destroy: devbox destroy ${_DB_NAME:-?})"
  elif [[ "${_DB_KEEP:-0}" -eq 1 ]]; then
    log "--keep: retained ${_DB_NAME:-?}"
    log "  re-enter: devbox $(printf '%q' "${_DB_DIR:-.}")$([[ "${_DB_IMAGE:-}" != "$DEFAULT_IMAGE" ]] && printf ' --image %q' "${_DB_IMAGE:-}")"
    log "  destroy:  devbox destroy ${_DB_NAME:-?}"
  elif [[ -n "${_DB_NAME:-}" ]]; then
    log "Destroying ${_DB_NAME}…"
    limactl stop -f "$_DB_NAME" 2>/dev/null || true
    limactl delete -f "$_DB_NAME" 2>/dev/null || true
  fi
  exit "$rc"
}

cmd_run() {
  local dir="" image="$DEFAULT_IMAGE" image_set=0 keep=0 with_creds=0 api_keys="" proxy="" no_auth=0 ssh_agent=0 name=""
  local extra_mounts=() extra_copies=() manifest_requests=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --image) shift; image="${1:?--image needs a value}"; image_set=1;;
      --image=*) image="${1#--image=}"; image_set=1;;
      --keep) keep=1;;
      --ssh-agent) ssh_agent=1;;
      --with-creds) with_creds=1;;
      --no-auth) no_auth=1;;
      --api-keys) api_keys="$DEFAULT_KEYS_FILE";;
      --api-keys=*) api_keys="$(abspath "${1#--api-keys=}")";;
      --proxy) proxy="$PROXY_DEFAULT_URL";;
      --proxy=*) proxy="${1#--proxy=}";;
      --mount) shift; extra_mounts+=("${1:?--mount needs PATH[:ro|:rw]}");;
      --mount=*) extra_mounts+=("${1#--mount=}");;
      --copy) shift; extra_copies+=("${1:?--copy needs SRC[:DEST]}");;
      --copy=*) extra_copies+=("${1#--copy=}");;
      --name) shift; name="${1:?--name needs a value}";;
      --name=*) name="${1#--name=}";;
      -h|--help) grep -E '^#( |$)' "$0" | sed -E 's/^# ?//'; return 0;;
      -*) die "unknown flag: $1 (see: devbox --help)";;
      *) dir="$1";;
    esac; shift
  done
  dir="$(abspath "${dir:-$PWD}")"
  [[ -d "$dir" ]] || die "not a directory: $dir"

  local manifest_path="$dir/$PROJECT_MANIFEST_NAME" manifest="" manifest_start=""
  if [[ -f "$manifest_path" ]]; then
    manifest="$(project_manifest "$manifest_path")" || die "invalid $PROJECT_MANIFEST_NAME"
    local manifest_image manifest_proxy manifest_api_keys manifest_mounts manifest_copies item
    manifest_image="$(manifest_value "$manifest" image)"
    [[ $image_set -eq 1 || -z "$manifest_image" ]] || image="$manifest_image"
    manifest_start="$(manifest_value "$manifest" start)"
    [[ -z "$manifest_start" ]] || manifest_requests+=("run startup command: $(printf '%q' "$manifest_start")")

    if [[ "$(manifest_value "$manifest" ssh_agent)" == True && $ssh_agent -eq 0 ]]; then
      ssh_agent=1
      manifest_requests+=("enable SSH agent forwarding")
    fi
    if [[ "$(manifest_value "$manifest" keep)" == True ]]; then
      keep=1
      manifest_requests+=("keep the devbox after exit")
    fi

    if [[ $no_auth -eq 0 ]]; then
      manifest_proxy="$(manifest_value "$manifest" proxy)"
      if [[ -z "$proxy" && "$manifest_proxy" != False ]]; then
        if [[ "$manifest_proxy" == True ]]; then proxy="$PROXY_DEFAULT_URL"; else proxy="$manifest_proxy"; fi
        manifest_requests+=("enable the AI authentication proxy")
      fi
      manifest_api_keys="$(manifest_value "$manifest" api_keys)"
      if [[ -z "$api_keys" && "$manifest_api_keys" != False ]]; then
        if [[ "$manifest_api_keys" == True ]]; then api_keys="$DEFAULT_KEYS_FILE"; else api_keys="$(abspath "$manifest_api_keys")"; fi
        manifest_requests+=("copy API keys into the devbox")
      fi
      if [[ "$(manifest_value "$manifest" with_creds)" == True && $with_creds -eq 0 ]]; then
        with_creds=1
        manifest_requests+=("copy AI credentials into the devbox")
      fi
    fi
    if [[ "$(manifest_value "$manifest" no_auth)" == True && $no_auth -eq 0 ]]; then
      no_auth=1
    fi

    manifest_mounts="$(manifest_json_value "$manifest" mounts)"
    while IFS= read -r item; do
      [[ -n "$item" ]] || continue
      extra_mounts+=("$item")
      case "$item" in
        *:rw) manifest_requests+=("mount ${item%:rw} read-write at ${item%:rw}");;
        *:ro) manifest_requests+=("mount ${item%:ro} read-only at ${item%:ro}");;
        *)    manifest_requests+=("mount $item read-only at $item");;
      esac
    done < <(python3 -c 'import json, sys; print(*json.load(sys.stdin), sep="\n")' <<< "$manifest_mounts")
    manifest_copies="$(manifest_json_value "$manifest" copies)"
    while IFS= read -r item; do
      [[ -n "$item" ]] || continue
      extra_copies+=("$item")
      manifest_requests+=("copy $(_copy_src "$item") to $(_copy_dest "$item")")
    done < <(python3 -c 'import json, sys; print(*json.load(sys.stdin), sep="\n")' <<< "$manifest_copies")
  fi
  if [[ $no_auth -eq 1 && ( -n "$proxy" || -n "$api_keys" || $with_creds -eq 1 ) ]]; then
    die "--no-auth cannot be combined with --proxy, --api-keys, or --with-creds"
  fi
  confirm_manifest_permissions "${manifest_requests[@]}"
  [[ $ssh_agent -eq 1 ]] && require_ssh_agent

  local golden; golden="$(golden_name "$image")"
  [[ -n "$name" ]] || name="$(instance_name "$image" "$dir")"

  local preexisting=0
  if instance_exists "$name"; then
    preexisting=1
    log "Attaching to existing box for this path: $name"
    [[ ${#extra_mounts[@]} -gt 0 ]] && warn "--mount only applies at box creation; destroy+recreate to change mounts (--copy still works)"
  else
    if ! instance_exists "$golden"; then
      log "No golden for image '$image' yet — building it first."
      cmd_build --image "$image"
    fi
    ensure_golden_stopped "$golden"
    local clone_args=(--mount "${dir}:w") m
    for m in "${extra_mounts[@]}"; do clone_args+=(--mount "$(_lima_mount_arg "$m")"); done
    log "Cloning $golden → $name (mount: $dir${extra_mounts:+, +${#extra_mounts[@]} extra mount(s)})"
    limactl clone "$golden" "$name" "${clone_args[@]}"
  fi
  [[ $ssh_agent -eq 1 ]] && enable_ssh_agent "$name"

  _DB_NAME="$name"; _DB_DIR="$dir"; _DB_IMAGE="$image"; _DB_KEEP="$keep"; _DB_PRE="$preexisting"
  trap run_cleanup EXIT INT TERM

  if [[ "$(instance_status "$name")" != "Running" ]]; then
    log "Booting $name…"; limactl start "$name"
  fi
  [[ $ssh_agent -eq 1 ]] && apply_git_signing "$name"

  if [[ $no_auth -eq 1 ]]; then
    clear_auth "$name"
  else
    [[ -n "$proxy" ]] && { proxy_ensure "$proxy"; apply_proxy "$name" "$proxy"; }
    [[ -n "$api_keys"  ]] && apply_api_keys "$name" "$api_keys"
    [[ $with_creds -eq 1 ]] && apply_creds  "$name"
  fi
  if [[ ${#extra_copies[@]} -gt 0 ]]; then
    local c; for c in "${extra_copies[@]}"; do apply_copy "$name" "$c"; done
  fi

  if [[ -n "$manifest" ]]; then
    local manifest_packages
    manifest_packages="$(manifest_json_value "$manifest" packages)"
    apply_project_packages "$name" "$manifest_packages"
    run_project_start "$name" "$dir" "$manifest_start"
  elif [[ -f "$dir/.devbox" ]]; then
    warn ".devbox is no longer executed; migrate it to $PROJECT_MANIFEST_NAME"
  fi

  local fate="destroy it"
  { [[ $preexisting -eq 1 || $keep -eq 1 ]]; } && fate="leave it running"
  log "Entering $name — exit the shell to $fate."
  limactl shell --workdir "$dir" "$name" || true
}

cmd_ls() { limactl list 2>/dev/null | awk 'NR==1 || $1 ~ /^devbox-/'; }

cmd_proxy() {
  local sub="${1:-status}" url="${DEVBOX_PROXY_URL:-$PROXY_DEFAULT_URL}" port pid
  port="$(proxy_port "$url")"
  case "$sub" in
    start)  proxy_ensure "$url";;
    stop)   pid="$(cat "$CONFIG_DIR/proxy.pid" 2>/dev/null || true)"
            if [[ -n "$pid" ]] && kill "$pid" 2>/dev/null; then
              log "stopped AI proxy (pid $pid)"; rm -f "$CONFIG_DIR/proxy.pid"
            elif pkill -f 'devbox-ai-proxy\.py' 2>/dev/null; then log "stopped AI proxy (matched by name)"
            else warn "no running AI proxy found"; fi;;
    status) if proxy_health "$port"; then log "AI proxy: RUNNING on 127.0.0.1:$port"
            elif proxy_port_open "$port"; then warn "port $port held by another (non-devbox) service"
            else log "AI proxy: not running (port $port)"; fi;;
    *) die "usage: devbox proxy [start|stop|status]";;
  esac
}

cmd_destroy() {
  local t="${1:-}"; [[ -n "$t" ]] || die "usage: devbox destroy NAME | --all | --goldens"
  local list
  case "$t" in
    --all)     list="$(limactl list -q 2>/dev/null | grep '^devbox-' | grep -v '^devbox-golden' || true)";;
    --goldens) list="$(limactl list -q 2>/dev/null | grep '^devbox-golden' || true)";;
    *)         list="$t";;
  esac
  [[ -n "$list" ]] || { log "nothing to destroy."; return 0; }
  while IFS= read -r i; do
    [[ -n "$i" ]] || continue
    log "destroying $i"
    limactl stop -f "$i" 2>/dev/null || true
    limactl delete -f "$i"
  done <<< "$list"
}

usage() { grep -E '^#( |$)' "$0" | sed -E 's/^# ?//'; }

# ----------------------------------------------------------------- dispatch --
# Only when executed directly — sourcing (e.g. from the bats tests) loads the
# functions without running anything.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  case "${1:-}" in
    -h|--help|help) usage; exit 0;;
    -V|--version|version) printf 'devbox %s\n' "$DEVBOX_VERSION"; exit 0;;
  esac
  need limactl
  case "${1:-}" in
    build)          shift; cmd_build   "$@";;
    ls|list)        shift; cmd_ls      "$@";;
    destroy|rm)     shift; cmd_destroy "$@";;
    proxy)          shift; cmd_proxy   "$@";;
    *)              cmd_run "$@";;
  esac
fi
