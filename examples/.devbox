#!/usr/bin/env bash
#
# Per-project devbox hook. Drop a copy of this in a project's root as
# `.devbox`. It runs INSIDE the disposable box after boot, as your user, in
# the mounted project directory. Use it to install project-specific tooling on
# top of the minimal golden baseline. Absent → skipped.
#
set -euo pipefail

# --- language toolchains (installed via the box's Homebrew) ---
# brew install node python@3.12 go rust

# --- project dependencies ---
# [ -f package.json ]        && npm install
# [ -f pyproject.toml ]      && pipx install . || pip install -e .
# [ -f go.mod ]              && go mod download

echo "devbox: .devbox ran (edit me to install project tooling)"
